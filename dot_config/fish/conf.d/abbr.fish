# pacman abbreviations
abbr -a 'pci' 'sudo pacman -S'
abbr -a 'pcu' 'sudo pacman -Syu'
abbr -a 'pcs' 'sudo pacman -Ss'

# apt  abbreviations
abbr -a 'agi' 'sudo apt install -y'
abbr -a 'agr' 'sudo apt remove'
abbr -a 'aguu' 'sudo apt update && sudo apt upgrade -y'
abbr -a 'agar' 'sudo apt autoremove'

# dnf abbreviations

abbr -a 'dnfu' 'sudo dnf install -y'
abbr -a 'dnfi' 'sudo dnf remove'
abbr -a 'dnfr' 'sudo dnf upgrade'
