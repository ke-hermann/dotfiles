export PATH=$HOME/go/bin:$PATH
export PATH=$HOME/.local/bin:$PATH
export PATH=$PATH:/home/linuxbrew/.linuxbrew/bin

# zoxide setup 
eval "$(zoxide init --cmd cd zsh)"

